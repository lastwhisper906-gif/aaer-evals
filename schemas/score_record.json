{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "score_record",
  "description": "케이스당 채점 기록. §7 협업 모델 반영: Claude 1차 판정 + 인간 서명/오버라이드. status: v1 (2026-07-03 사용자 일괄 승인)",
  "type": "object",
  "required": ["case_id", "run_id", "scored_against_protocol_version", "item_scores", "case_verdict", "sign_off"],
  "properties": {
    "case_id": { "type": "string" },
    "run_id": { "type": "string" },
    "scored_against_protocol_version": { "type": "string", "description": "채점 프로토콜 문서의 git commit hash — 사전 고정 증적 (§5-6)" },
    "item_scores": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "verdict", "rationale", "proposed_by"],
        "properties": {
          "item_id": { "type": "string" },
          "verdict": { "type": "string", "enum": ["correct", "incorrect", "not_scoreable"] },
          "rationale": { "type": "string", "description": "AAER 원문 대조 근거. 근거 없는 판정은 무효 (§7 서명 규칙)" },
          "signal_channel": { "type": "string", "enum": ["numeric", "textual", "both"], "description": "수치 지표로도 잡혔을 신호인지, 텍스트에서만 잡히는 신호인지 — trust boundary 분석용" },
          "proposed_by": { "type": "string", "enum": ["claude", "human"] },
          "learning_note": { "type": "string", "description": "이 판단에서 알아야 할 것 한 줄 (§10)" }
        }
      }
    },
    "case_verdict": {
      "type": "object",
      "required": ["outcome"],
      "properties": {
        "outcome": { "type": "string", "enum": ["true_positive", "false_negative", "true_negative", "false_positive", "not_scoreable"] },
        "notes": { "type": "string" }
      }
    },
    "error_attribution": {
      "type": ["object", "null"],
      "description": "Week 3에 기입. incorrect/false_* 항목에만 해당",
      "properties": {
        "category": { "type": "string", "enum": ["pipeline_error", "llm_judgment_error", "ground_truth_ambiguous"] },
        "rationale": { "type": "string" },
        "proposed_by": { "type": "string", "enum": ["claude", "human"] },
        "human_reviewed": { "type": "boolean", "description": "llm_judgment_error는 전수 true 필수 (§7)" }
      }
    },
    "sign_off": {
      "type": "object",
      "required": ["status", "date"],
      "properties": {
        "status": { "type": "string", "enum": ["signed", "overridden", "pending"] },
        "date": { "type": ["string", "null"], "format": "date" },
        "override_ref": { "type": ["string", "null"], "description": "overridden인 경우 scoring/overrides.md 항목 ID" }
      }
    }
  }
}
